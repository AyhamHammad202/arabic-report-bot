# ============================================================
# Arabic Language Report Bot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# Your Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram User ID of the Admin/Professor (get it from @userinfobot)
ADMIN_ID=123456789

# Telegram User ID of the Super Admin (can be the same as ADMIN_ID,
# or a different person with elevated deletion privileges)
SUPER_ADMIN_ID=8289679330
