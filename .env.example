# ============================================================
# Arabic Language Report Bot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# Your Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram User ID of the Admin/Professor (get it from @userinfobot)
ADMIN_ID=123456789

# Telegram User ID of the Super Admin (can be the same as ADMIN_ID)
SUPER_ADMIN_ID=123456789

# ── Firebase Credentials ──────────────────────────────────────
#
# OPTION A — Local development (recommended for running on your PC):
#   1. Download your Firebase service account JSON from:
#      Firebase Console → Project Settings → Service Accounts → Generate new private key
#   2. Save the file as  firebase-credentials.json  in the project root
#   3. Add  firebase-credentials.json  to .gitignore  (already done)
#   Leave FIREBASE_CREDENTIALS empty when using a file:
FIREBASE_CREDENTIALS=
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
#
# OPTION B — Cloud deployment (Render / Railway):
#   Paste the ENTIRE content of your service account JSON as a single line:
#   FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"..."}
#   Leave FIREBASE_CREDENTIALS_PATH empty.
